inned":false,"source":"gallery","id":"c46b0018-f317-4b6c-a785-d2039b27338f","publisherId":"7a344d8a-64ec-42a7-9255-9eacf94e746a","publisherDisplayName":"Wix","targetPlatform":"undefined","updated":false,"private":false,"isPreReleaseVersion":false,"hasPreReleaseVersion":false,"preRelease":false,"size":46693315},"isValid":true,"validations":[],"preRelease":false,"forceAutoUpdate":false},{"type":1,"identifier":{"id":"wallabyjs.console-ninja","uuid":"6a994cdf-21a5-4e80-b0a5-601acdad9bf9"},"manifest":{"name":"console-ninja","displayName":"Console Ninja","publisher":"WallabyJs","author":"Wallaby.js","icon":"images/logo.png","homepage":"https://console-ninja.com","bugs":{"url":"https://github.com/wallabyjs/console-ninja/issues"},"repository":{},"description":"JavaScript console.log output and runtime errors right next to your code.","version":"1.0.525","engines":{"vscode":"^1.64.0"},"categories":["Debuggers","Other","AI","Chat"],"keywords":["chat-participant","language-model-tools","debugger","javascript","typescript"],"activationEvents":["onStartupFinished"],"main":"./out/extension/index.js","contributes":{"viewsContainers":{"activitybar":[{"id":"console-ninja","title":"Console Ninja","icon":"images/monochrome-logo.svg"}],"panel":[{"id":"console-ninja-panel","title":"Console Ninja","icon":"images/monochrome-logo.svg"}]},"views":{"console-ninja":[{"id":"console-ninja.output","name":"Output","type":"webview","contextualTitle":"Console Output","icon":"images/monochrome-logo.svg","visibility":"visible","when":"console-ninja.started && console-ninja.outputMode.view && !console-ninja.v2"}],"console-ninja-panel":[{"id":"console-ninja.panel","name":"Output","type":"webview","contextualTitle":"Console Ninja","icon":"images/monochrome-logo.svg","visibility":"visible","when":"console-ninja.started && console-ninja.v2"}]},"configuration":[{"id":"general","title":"General","order":0,"properties":{"console-ninja.toolsToEnableSupportAutomaticallyFor":{"order":0,"scope":"resource","type":"object","default":{"vite":true,"angular":true,"jest":true,"webpack":true,"next.js":true,"nest.js":true,"cypress":true,"http-server":true,"serve":true,"live-server":true,"nuxt":true,"remix":true,"qwik":true,"hydrogen":true,"serverless":true,"astro":true,"react-native":true,"live-server-extension":false,"live-preview-extension":false},"properties":{"webpack":{"type":"boolean","description":"Webpack powered apps (such as Create React App or Angular CLI app)"},"vite":{"type":"boolean","description":"Vite powered apps"},"angular":{"type":"boolean","description":"Angular CLI powered apps"},"jest":{"type":"boolean","description":"Jest"},"cypress":{"type":"boolean","description":"Cypress.io"},"next.js":{"type":"boolean","description":"Next.js"},"nest.js":{"type":"boolean","description":"Nest.js"},"http-server":{"type":"boolean","description":"`http-server` node module"},"serve":{"type":"boolean","description":"`serve` node module"},"live-server":{"type":"boolean","description":"`live-server` node module"},"nuxt":{"type":"boolean","description":"Nuxt Vue.js"},"remix":{"type":"boolean","description":"Remix"},"qwik":{"type":"boolean","description":"Qwik"},"hydrogen":{"type":"boolean","description":"Shopify's Hydrogen"},"serverless":{"type":"boolean","description":"Serverless Offline"},"astro":{"type":"boolean","description":"Astro"},"react-native":{"type":"boolean","description":"(PRO feature) React Native (iOS and Android emulators)"},"live-server-extension":{"type":"boolean","description":"Live Server extension (restart editor after changing this setting)"},"live-preview-extension":{"type":"boolean","description":"Live Preview extension (restart editor after changing this setting)"}},"additionalProperties":false,"markdownDescription":"Tools (node modules and extensions) to automatically enable Console Ninja for."},"console-ninja.allowedHosts":{"order":1,"scope":"resource","type":"array","items":{"type":"string"},"uniqueItems":true,"markdownDescription":"The list of host names that may connect to Console Ninja. Defaults to the current machine IP addresses and host name (`localhost`, `127.0.0.1`, `example.cypress.io`, `10.0.2.2`, `os.hostname()`, Network Adapter IP v4 Addresses).\n\n(**PRO feature**) also supports the use of `*` and `?` for wildcard matching (e.g. `*.example.com`), and regular expressions (e.g. `/^.*\\\\.example\\\\.com$/`).\n\nAdd additional host names if you need to connect to Console Ninja from a different/custom host name **(restart editor after changing this setting)**."},"console-ninja.showWhatsNew":{"order":2,"markdownDescription":"Display information about new features when they are released.","type":"boolean","default":true},"console-ninja.featureSet":{"order":5,"type":"string","default":"Pro","markdownDescription":"Choose whether to use Pro or Community feature set.","enum":["Pro","Community"],"enumDescriptions":["Use all Console Ninja features","Only use Console Ninja features that will be available in the free Community Edition"]},"console-ninja.installBinToPath":{"order":4,"scope":"resource","type":"boolean","default":false,"markdownDescription":"Automatically install [console-ninja](https://github.com/wallabyjs/console-ninja#universal-node-applications) command to `PATH`."},"console-ninja.syncSettings":{"order":6,"description":"Synchronize subscription details and other settings as a part of VS Code Settings Sync","type":"boolean","default":true},"console-ninja.predictiveLoggingEnabled":{"order":7,"markdownDescription":"(**PRO feature**) Enable Predictive Logging \n\n _(Always disabled for Community edition)_","type":"boolean","default":true},"console-ninja.allowConsoleLogToTriggerPredictions":{"order":8,"markdownDescription":"(**PRO feature**) Allow `console.log` to trigger predictions \n\n _(Always disabled for Community edition)_","type":"boolean","default":false},"console-ninja.warnOnNoToolsDetected":{"order":9,"markdownDescription":"Warn when no supported tools are detected.","type":"boolean","default":true}}},{"id":"log-viewer","title":"Log Viewer","order":1,"properties":{"console-ninja.outputMode":{"order":0,"markdownDescription":"(**Deprecated**) Specifies how [Console Ninja Output](https://github.com/wallabyjs/console-ninja#log-viewer) is displayed.","type":"string","default":"Beside File","enum":["Beside File","In View"],"enumDescriptions":["Opens Console Ninja Output beside your current file","Opens Console Ninja Output in a separate view"]},"console-ninja.dateTimeFormat":{"order":1,"scope":"resource","type":"string","default":"HH:mm:ss.SSS","markdownDescription":"[Format string](https://day.js.org/docs/en/display/format) for displaying [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer) entry date and time (**empty string** to disable date and time display)."},"console-ninja.dateTimeDisplayMode":{"order":2,"scope":"resource","enum":["Relative To Oldest","Relative To Previous","Absolute","None"],"markdownEnumDescriptions":["(**PRO feature**) Displays time relative to the oldest entry in the log viewer","(**PRO feature**) Displays time relative to the previous entry in the log viewer","Displays absolute date and time","Does not display date and time"],"default":"Absolute","markdownDescription":"Default display mode for [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer) entry date and time."},"console-ninja.fontSize":{"order":3,"scope":"resource","type":"integer","markdownDescription":"Controls the font size (in pixels) of the [Console Ninja Output](https://github.com/wallabyjs/console-ninja#log-viewer)."},"console-ninja.autoClearLogViewerOnFileChanges":{"order":4,"scope":"resource","type":"boolean","default":true,"markdownDescription":"Clear [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer) entries when any file changes (default value after editor restart)."},"console-ninja.openHttpLinksInEditor":{"order":5,"scope":"resource","type":"boolean","default":true,"markdownDescription":"Open `http`/`https` source links in editor as new file."},"console-ninja.maxLogViewerEntries":{"order":6,"scope":"resource","type":"integer","default":15000,"markdownDescription":"Maximum number of entries to display in the [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer)."},"console-ninja.showWelcomeMessageInTools":{"order":7,"scope":"resource","type":"boolean","default":true,"markdownDescription":"Display notification that Console Ninja is running into build tools CLI and browser developer tools console."},"console-ninja.logCaptureOptions":{"order":8,"scope":"resource","type":"object","default":{"resolveGetters":false,"defaultLimits":{"props":100,"elements":100,"strLength":51200,"totalStrLength":51200,"autoExpandLimit":5000,"autoExpandMaxDepth":10},"reducedLimits":{"props":5,"elements":5,"strLength":256,"totalStrLength":768,"autoExpandLimit":30,"autoExpandMaxDepth":2},"reducePolicy":{"perLogpoint":{"reduceOnCount":50,"reduceOnAccumulatedProcessingTimeMs":100,"resetWhenQuietMs":500,"resetOnProcessingTimeAverageMs":100},"global":{"reduceOnCount":1000,"reduceOnAccumulatedProcessingTimeMs":300,"resetWhenQuietMs":50,"resetOnProcessingTimeAverageMs":100}}},"markdownDescription":"Configure runtime value serialization and traversal limits (e.g. resolving getters, default vs. reduced limits, and reduction policy). See the README for detailed options: [Runtime Log Capture Options](https://github.com/wallabyjs/console-ninja#runtime-log-capture-options).\n\n(requires restarting the editor and your dev tool after change)"},"console-ninja.autoDisplayOutputPanel":{"order":9,"scope":"resource","type":"boolean","default":true,"markdownDescription":"Automatically open the output panel when the app produces logs or errors"}}},{"id":"filtering","title":"Output Filtering","order":2,"properties":{"console-ninja.output.showErrors":{"order":1,"scope":"resource","type":"boolean","default":true,"markdownDescription":"(**PRO feature**) Capture and display errors. \n\n _(Always enabled for Community edition)_"},"console-ninja.output.showLogsOnlyFromOpenedFiles":{"order":2,"scope":"resource","type":"boolean","default":false,"markdownDescription":"(**PRO feature**) Capture and display logs only from files opened in editor. \n\n _(Always disabled for Community edition)_"},"console-ninja.output.showLogsFromMultipleRunningToolsTogether":{"order":3,"scope":"resource","type":"boolean","default":false,"markdownDescription":"(**PRO feature**) Display logs from multiple running tools together in a single list in [log viewer](https://github.com/wallabyjs/console-ninja#log-viewer). \n\n _(Always disabled for Community edition)_"},"console-ninja.output.showLogsFromLogPointsOnly":{"order":4,"scope":"resource","type":"boolean","default":false,"markdownDescription":"(**PRO feature**) Capture and display logs only from [logpoints](https://github.com/wallabyjs/console-ninja#logpoints), [function logpoints](https://github.com/wallabyjs/console-ninja#function-logpoints), [tracepoints](https://github.com/wallabyjs/console-ninja#tracepoints) and [timepoints](https://github.com/wallabyjs/console-ninja#timepoints), and do not capture `console.log`, `console.trace`, `console.time`, `console.warn`, `console.info`, or `console.debug`. \n\n _(Always disabled for Community edition)_"},"console-ninja.captureFunctions":{"order":5,"scope":"resource","type":"boolean","default":false,"markdownDescription":"Include function names found inside logged objects."},"console-ninja.output.showNetworkRequests":{"order":6,"scope":"resource","type":"boolean","default":true,"markdownDescription":"(**PRO feature**) Capture and display network requests. \n\n _(Always enabled with reduced functionality for Community edition)_"}}},{"id":"inline","title":"Inline Decorations","order":3,"properties":{"console-ninja.lightTheme.log.decorationAttachmentRenderOptions":{"description":"Inline log text render options for light themes.","type":"object","default":{"border":null,"borderColor":null,"fontStyle":null,"fontWeight":null,"textDecoration":null,"color":"#0000ff","backgroundColor":null,"margin":"1em","width":null,"height":null}},"console-ninja.lightTheme.error.decorationAttachmentRenderOptions":{"description":"Inline error text render options for light themes.","type":"object","default":{"border":null,"borderColor":null,"fontStyle":null,"fontWeight":null,"textDecoration":null,"color":"#c80000","backgroundColor":null,"margin":"1em","width":null,"height":null}},"console-ninja.lightTheme.obsolete.decorationAttachmentRenderOptions":{"description":"Inline obsolete message text render options for light themes.","type":"object","default":{"border":null,"borderColor":null,"fontStyle":null,"fontWeight":null,"textDecoration":null,"color":"rgb(153, 153, 153)","backgroundColor":null,"margin":"1em","width":null,"height":null}},"console-ninja.darkTheme.log.decorationAttachmentRenderOptions":{"description":"Inline log text render options for dark themes.","type":"object","default":{"border":null,"borderColor":null,"fontStyle":null,"fontWeight":null,"textDecoration":null,"color":"rgba(86, 156, 214, 1)","backgroundColor":null,"margin":"1em","width":null,"height":null}},"console-ninja.darkTheme.error.decorationAttachmentRenderOptions":{"description":"Inline error text render options for dark themes.","type":"object","default":{"border":null,"borderColor":null,"fontStyle":null,"fontWeight":null,"textDecoration":null,"color":"#fe536a","backgroundColor":null,"margin":"1em","width":null,"height":null}},"console-ninja.darkTheme.obsolete.decorationAttachmentRenderOptions":{"description":"Inline obsolete message text render options for dark themes.","type":"object","default":{"border":null,"borderColor":null,"fontStyle":null,"fontWeight":null,"textDecoration":null,"color":"rgb(153, 153, 153)","backgroundColor":null,"margin":"1em","width":null,"height":null}},"console-ninja.darkTheme.gutterIcons":{"description":"Gutter indicators colors for dark themes (requires a restart after change)","type":"obje