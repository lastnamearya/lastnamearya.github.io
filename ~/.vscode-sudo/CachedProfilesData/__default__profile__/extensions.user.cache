 AI","category":"Console Ninja"},{"command":"console-ninja.modifyMcpJson","title":"Modify MCP settings file","category":"Console Ninja"},{"command":"console-ninja.openMcpSettings","title":"Open MCP settings","category":"Console Ninja"},{"command":"console-ninja.installBinToPath","title":"Install 'console-ninja' command","category":"Console Ninja"},{"command":"console-ninja.uninstallBinFromPath","title":"Uninstall 'console-ninja' command","category":"Console Ninja"},{"command":"console-ninja.enableOutputPanelAutoDisplay","title":"Enable Output Panel Auto Display","category":"Console Ninja","icon":"$(bell-slash)"},{"command":"console-ninja.disableOutputPanelAutoDisplay","title":"Disable Output Panel Auto Display","category":"Console Ninja","icon":"$(bell)"}],"grammars":[],"languages":[],"menus":{"commandPalette":[{"command":"console-ninja.start","when":"!console-ninja.started && console-ninja.canBeStarted"},{"command":"console-ninja.pause","when":"console-ninja.started"},{"command":"console-ninja.clearOutput","when":"true"},{"command":"console-ninja.showOutput","when":"console-ninja.started"},{"command":"console-ninja.selectAction","when":"false"},{"command":"console-ninja.reloadBrowserPage","when":"console-ninja.browserRuntimeConnected"},{"command":"console-ninja.goToLatestErrorSource","when":"console-ninja.hasAnError"},{"command":"console-ninja.addTimepoint","when":"console-ninja.started && console-ninja.pro"},{"command":"console-ninja.addTracepoint","when":"console-ninja.started && console-ninja.pro"},{"command":"console-ninja.selectProject","when":"workspaceFolderCount > 1"},{"command":"console-ninja.copyLineEntryValue","when":"console-ninja.started && console-ninja.pro"},{"command":"console-ninja.showAsDiagram","when":"console-ninja.started && console-ninja.pro"},{"command":"console-ninja.toggleLineHighlight","when":"console-ninja.started && console-ninja.pro"},{"command":"console-ninja.removeAllHighlights","when":"console-ninja.started && console-ninja.pro"},{"c